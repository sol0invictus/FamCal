rules_version = '2';

// FamCal Firestore security rules.
// Paste these into the Firebase console (Firestore Database -> Rules) and Publish,
// or deploy with the Firebase CLI: `firebase deploy --only firestore:rules`.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function familyMembers(familyId) {
      return get(/databases/$(database)/documents/families/$(familyId)).data.memberUids;
    }

    // A user can only read/write their own profile document.
    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Invite lookup docs, keyed by the (random) invite code. Anyone signed in can
    // resolve a code they already know by fetching it directly by id; listing is
    // denied so codes can't be discovered. Only the family owner manages them.
    match /invites/{code} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /families/{familyId} {
      // Only members can see a family's data.
      allow get, list: if signedIn() && request.auth.uid in resource.data.memberUids;

      // Creating a family: you must be its owner and a member.
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids;

      // Members can update freely. A non-member may update ONLY to add themselves to
      // memberUids (joining via an invite): they weren't a member, they are now, every
      // existing member is preserved, and the list grew by exactly one.
      allow update: if (
          signedIn()
          && request.auth.uid in resource.data.memberUids
          && request.resource.data.ownerUid == resource.data.ownerUid
        )
        || (
          signedIn()
          && !(request.auth.uid in resource.data.memberUids)
          && request.auth.uid in request.resource.data.memberUids
          && request.resource.data.memberUids.hasAll(resource.data.memberUids)
          && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
        );

      // Only the owner can delete the whole family.
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;

      match /members/{memberId} {
        allow read: if signedIn() && request.auth.uid in familyMembers(familyId);
        // You may only create/modify your own member document.
        allow create, update, delete: if signedIn() && request.auth.uid == memberId;
      }

      // Events: readable by any member; an event must be created by its author.
      match /events/{eventId} {
        allow read: if signedIn() && request.auth.uid in familyMembers(familyId);
        allow create: if signedIn()
          && request.auth.uid in familyMembers(familyId)
          && request.resource.data.createdBy == request.auth.uid;
        allow update, delete: if signedIn() && request.auth.uid in familyMembers(familyId);
      }

      // Shared lists and their items: readable/writable by any family member.
      match /lists/{listId} {
        allow read, write: if signedIn() && request.auth.uid in familyMembers(familyId);

        match /items/{itemId} {
          allow read, write: if signedIn() && request.auth.uid in familyMembers(familyId);
        }
      }
    }
  }
}
